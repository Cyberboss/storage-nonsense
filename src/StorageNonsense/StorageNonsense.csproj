<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup Condition="'$(STORAGE_NONSENSE_VERSION)' != ''">
    <Version>$(STORAGE_NONSENSE_VERSION)</Version>
  </PropertyGroup>

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <OutputType>exe</OutputType>
    <PublishSingleFile Condition="'$(Configuration)' == 'Release'">true</PublishSingleFile>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="10.0.10" />
    <PackageReference Include="System.Management" Version="10.0.10" />
    <PackageReference Include="TestableIO.System.IO.Abstractions.Wrappers" Version="22.2.0" />
  </ItemGroup>

</Project>
